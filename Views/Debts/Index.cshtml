@model IEnumerable<ShareCare.Models.Debt>

@{
    ViewData["Title"] = "Index";
    var controller = "Debts";
}

<h1>Index</h1>

<p>
    <a asp-controller=@controller asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Purchase)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UploaderUser)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.OwerUser)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Amount)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ApprovalState)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PaymentState)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Purchase.Note)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UploaderUser.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.OwerUser.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Amount)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ApprovalState)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PaymentState)
            </td>
            <td>
                    <a asp-controller=@controller asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-controller=@controller asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-controller=@controller asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
