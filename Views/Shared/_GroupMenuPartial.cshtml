<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script>
    $(document).ready(function () {
        $(".hover-dropdown").hover(
            function () {
                $(this).addClass("show");
                $(this).find(".dropdown-menu").stop(true, true).slideDown(300).addClass("show");
            },
            function () {
                $(this).removeClass("show");
                $(this).find(".dropdown-menu").stop(true, true).slideUp(300).removeClass("show");
            }
        );
    });
</script>
<style>
    li:hover {
        background-color: #f1f1f1; /* Light gray background */
        color: #333; /* Darker text color */
    }
</style>