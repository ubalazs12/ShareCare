@using Microsoft.AspNetCore.Identity
@using ShareCare.Data
@using ShareCare.Models

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <form id="logoutForm" class="form-inline" asp-controller="Account" asp-action="LogOff" method="post">
            <button id="logout" type="submit" class="nav-link btn btn-link text-light border-0">Kijelentkezés</button>
        </form>
        </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link link-light link-opacity-50-hover" id="register" asp-controller="Account" asp-action="Register">Regisztráció</a>
    </li>
    <li class="nav-item">
            <a class="nav-link link-light link-opacity-50-hover" id="login" asp-controller="Account" asp-action="Login">Bejelentkezés</a>
    </li>
}
</ul>