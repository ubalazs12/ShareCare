                            @totalDebt.Key.Item2.FullName
                        </td>
                        <td>
                            @arrow
                        </td>
                        <td class="text-nowrap">
                            @totalDebt.Key.Item1.FullName
                        </td>
                        <td class="text-end">
                            @totalDebt.Value
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<div id="totalDebtsSimplest" class="hidden">
    <h1>Egyszerűsített tartozások (kölcsönös és körtartozás)</h1>

    <table class="table align-middle w-100">
        <thead>
