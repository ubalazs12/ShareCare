                }
            }
        </tbody>
    </table>
</div>

<style>
    .hidden {
        display: none;
    }
</style>

<script>
    function toggleDiv(divId) {
        var list = ["totalDebts", "totalDebtsSimpler", "totalDebtsSimplest"];
        list.forEach((item, index) => {
            if (item === divId) 
            { 
                document.getElementById(item).style.display = "block";
            }
            else
            {
                document.getElementById(item).style.display = "none";
            }
        });
    }
</script>