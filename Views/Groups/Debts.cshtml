                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var totalDebt in totalDebtsSimplest)
            {
                if (true)
                {
                    <tr>
                        <td class="text-nowrap">
                            @totalDebt.Key.Item2.FullName
                        </td>
                        <td>
