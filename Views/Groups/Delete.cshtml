@model ShareCare.Models.Group

@{
    ViewData["Title"] = "Delete";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Törlés</h1>

<h3>Biztosan törölni szeretné a csoportot?</h3>
<div>
    <hr />    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Törlés" class="btn btn-danger" />
    </form>
</div>
<div class="mt-1">
    <a class="text-decoration-none" asp-action="Index">Mégse</a>
</div>
