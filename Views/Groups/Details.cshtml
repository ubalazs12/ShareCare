@using ShareCare.Data
@model ShareCare.Models.Group

@{
    ViewData["Title"] = "Details";
    ViewData["Group"] = Model;
    ViewData["GroupId"] = Model.Id;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var controller = "Groups";
}

<h1>@Html.DisplayFor(model => model.Name)</h1>

<div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.CreatorUser)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.CreatorUser.FullName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Users)
        </dt>
        <dd class="col-sm-10">
            @foreach (var user in ViewData["Users"] as List<ApplicationUser>)
            {
                <p class="m-0">
                    @user.FullName
                </p>
            }
        </dd>
        <dt class="col-sm-2">
            Meghívó kód
        </dt>
        <dd class="col-sm-10 user-select-all">
            @Html.DisplayFor(model => model.Id)
        </dd>
        @* <dt class="col-sm-2">
            Invite link
        </dt>
        <dd class="col-sm-10">
            @ViewData["InviteLink"]
        </dd> *@
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Szerkesztés</a> |
    <a asp-action="Index">Vissza</a>
</div>
